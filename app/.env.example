# ─────────────────────────────────────────────────────────────────
# SERVER-SIDE — consumed only by /api/analyze (Vercel Edge Function)
# NEVER add a VITE_ prefix here — this key must not reach the browser
# ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────
# CLIENT-SIDE — leave as the placeholder below to run in demo mode
# The app auto-detects placeholder values and uses mock data instead
# Apply for a key: https://forms.gle/2nuJT2qNbUQsyyZy8
# ─────────────────────────────────────────────────────────────────
SOSOVALUE_API_KEY=your_sosovalue_api_key_here
VITE_DYNAMIC_ENVIRONMENT_ID=your_dynamic_environment_id_here
